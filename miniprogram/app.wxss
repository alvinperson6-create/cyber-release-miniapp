/* app.wxss — 全局样式 */

page {
  --teal: #2c8a7a;
  --teal-deep: #1f3a36;
  --teal-light: #d4e8e2;
  --coral: #ed7d5b;
  --coral-soft: #fce8df;
  --lake: #3e7a96;
  --paper: #faf6ec;
  --paper-warm: #f5ede0;
  --ink: #2a2a2a;
  --ink-soft: #555;
  --ink-mute: #999;
  --line: #e0ddd5;
  --line-soft: #eeebe5;

  background: var(--paper);
  color: var(--ink);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用卡片 */
.card {
  background: #fff;
  border: 1px solid var(--line-soft);
  border-radius: 12rpx;
  padding: 24rpx;
}

/* 通用按钮 */
.btn-primary {
  background: var(--teal);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary[disabled] {
  background: var(--line);
  color: var(--ink-mute);
}

.btn-line {
  background: transparent;
  color: var(--teal-deep);
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  text-align: center;
}

/* 面板标签 */
.panel-label {
  font-size: 24rpx;
  color: var(--ink-mute);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

/* 筹码按钮 */
.chip {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  border-radius: 99rpx;
  border: 2rpx solid var(--line);
  font-size: 26rpx;
  color: var(--ink-soft);
  background: #fff;
  margin-right: 16rpx;
}

.chip.active {
  background: var(--coral-soft);
  border-color: var(--coral);
  color: var(--coral);
}

.chip.active.teal {
  background: var(--teal-light);
  border-color: var(--teal);
  color: var(--teal-deep);
}
