<!-- 收据弹窗 -->
<view class="receipt-overlay {{show ? 'show' : ''}}" bindtap="onOverlayTap" data-role="overlay" wx:if="{{show}}">
  <view class="receipt-card" catchtap="noop">
    <view class="receipt-head">
      <view class="receipt-stamp">放生成功</view>
      <view class="receipt-sub">CYBER RELEASE RECEIPT</view>
    </view>

    <view class="receipt-rows">
      <view class="receipt-row">
        <text class="row-key">护生编号</text>
        <text class="row-val mono">{{receipt.id}}</text>
      </view>
      <view class="receipt-row">
        <text class="row-key">放生地点</text>
        <text class="row-val serif">{{receipt.waterName}}</text>
      </view>
      <view class="receipt-row">
        <text class="row-key">电子生物</text>
        <text class="row-val">{{receipt.creatureEmoji}} {{receipt.creatureName}}</text>
      </view>
      <view class="receipt-row">
        <text class="row-key">放生时间</text>
        <text class="row-val mono">{{receipt.timeStr}}</text>
      </view>
    </view>

    <view class="receipt-feeling">
      <view class="block-label">— 此刻感受 —</view>
      <view class="block-text">{{receipt.feeling || '（这次没说，没关系）'}}</view>
    </view>

    <view class="receipt-sign">
      <view class="block-label">— 本日好运签 —</view>
      <view class="block-text">{{receipt.sign}}</view>
    </view>

    <view class="receipt-feedback">
      <view class="feedback-icon">📬</view>
      <view class="feedback-body">
        <view class="block-label">AI 回信安排</view>
        <view class="feedback-text"><text class="strong">{{receipt.feedbackLabel}}</text> 以图文形式推送，基于你此刻的感受生成 · <text class="mute">可能治愈、可能搞怪</text></view>
      </view>
    </view>

    <view class="receipt-actions">
      <button class="btn-line {{shareClicked ? 'btn-line-active' : ''}}" bindtap="onShareTap">
        {{shareClicked ? '✓ 已生成卡片' : '分享到群'}}
      </button>
      <button class="btn-primary" bindtap="onAgainTap">再来一只</button>
    </view>

    <view class="receipt-foot">
      <text>* 本回执不构成任何好运承诺 / 也不鼓励线下放生</text>
      <text>仅作虚拟情绪仪式使用 · 编号随机</text>
    </view>
  </view>
</view>
