/* ==================== 收据弹窗 ==================== */
/* 严格还原 HTML 手机原型 receipt 设计 */

.receipt-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(31, 58, 54, 0.55);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s;
  z-index: 100;
  padding: 40rpx;
}

.receipt-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.receipt-card {
  width: 100%;
  max-height: 88vh;
  overflow-y: auto;
  background: #fdfaf2;
  border-radius: 28rpx;
  padding: 44rpx 36rpx 36rpx;
  transform: translateY(80rpx);
  transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.3, 1);
  box-shadow: 0 16rpx 56rpx rgba(0, 0, 0, 0.2);
  position: relative;
}

.receipt-overlay.show .receipt-card {
  transform: translateY(0);
}

/* 穿孔边缘 (上下) */
.receipt-card::before,
.receipt-card::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 16rpx;
  background-image: radial-gradient(circle, var(--paper) 8rpx, transparent 8rpx);
  background-size: 28rpx 16rpx;
  background-repeat: repeat-x;
  z-index: 1;
}

.receipt-card::before {
  top: -8rpx;
}

.receipt-card::after {
  bottom: -8rpx;
  transform: rotate(180deg);
}

/* ==================== 回执头部 ==================== */
.receipt-head {
  text-align: center;
  padding-bottom: 28rpx;
  border-bottom: 1rpx dashed var(--line);
  margin-bottom: 28rpx;
}

.receipt-stamp {
  display: inline-block;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 44rpx;
  color: var(--coral);
  letter-spacing: 0.4em;
  padding: 8rpx 24rpx 8rpx 32rpx;
  border: 4rpx solid var(--coral);
  border-radius: 8rpx;
  transform: rotate(-3deg);
  margin-bottom: 16rpx;
}

.receipt-sub {
  font-size: 22rpx;
  color: var(--ink-mute);
  letter-spacing: 0.1em;
}

/* ==================== 信息行 ==================== */
.receipt-rows {
  margin-bottom: 8rpx;
}

.receipt-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--ink-soft);
  padding: 12rpx 0;
}

.receipt-row .row-key {
  color: var(--ink-mute);
}

.receipt-row .row-val {
  color: var(--ink);
}

.receipt-row .row-val.mono {
  font-family: "SF Mono", "Monaco", monospace;
  font-size: 22rpx;
}

.receipt-row .row-val.serif {
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 26rpx;
}

/* ==================== 此刻感受块 ==================== */
.receipt-feeling {
  margin: 24rpx 0;
  padding: 20rpx 24rpx;
  background: var(--paper-warm);
  border-radius: 12rpx;
  border-left: 6rpx solid var(--coral);
}

/* ==================== 好运签块 ==================== */
.receipt-sign {
  margin: 24rpx 0;
  padding: 24rpx;
  background: var(--teal-light);
  border-radius: 12rpx;
  text-align: center;
}

/* ==================== AI 回信安排块 ==================== */
.receipt-feedback {
  margin: 24rpx 0 0;
  padding: 20rpx 24rpx;
  background: var(--teal-light);
  border-radius: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.feedback-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  line-height: 1;
}

.feedback-body {
  flex: 1;
  min-width: 0;
}

/* ==================== 区块标签和文本 ==================== */
.block-label {
  font-size: 20rpx;
  letter-spacing: 0.12em;
  margin-bottom: 8rpx;
}

.receipt-feeling .block-label {
  color: var(--coral);
}

.receipt-sign .block-label {
  color: var(--teal-deep);
}

.receipt-feedback .block-label {
  color: var(--teal-deep);
}

.block-text {
  font-size: 24rpx;
  color: var(--ink);
  line-height: 1.6;
}

.receipt-feeling .block-text {
  font-style: italic;
}

.receipt-sign .block-text {
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 32rpx;
  line-height: 1.5;
}

.feedback-text {
  font-size: 22rpx;
  color: var(--ink-soft);
  line-height: 1.5;
}

.feedback-text .strong {
  color: var(--teal-deep);
  font-weight: 600;
}

.feedback-text .mute {
  color: var(--ink-mute);
}

/* ==================== 按钮组 ==================== */
.receipt-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-line {
  flex: 1;
  padding: 18rpx 0;
  background: transparent;
  border: 2rpx solid var(--line);
  border-radius: 99rpx;
  font-size: 24rpx;
  color: var(--ink-soft);
  transition: all 0.2s;
}

.btn-line-active {
  border-color: var(--teal);
  color: var(--teal);
}

.btn-primary {
  flex: 1;
  padding: 18rpx 0;
  background: var(--ink);
  color: var(--paper);
  border-radius: 99rpx;
  font-size: 24rpx;
  letter-spacing: 0.04em;
  transition: all 0.2s;
}

/* ==================== 底部免责声明 ==================== */
.receipt-foot {
  text-align: center;
  font-size: 20rpx;
  color: var(--ink-mute);
  margin-top: 24rpx;
  letter-spacing: 0.04em;
  line-height: 1.5;
  display: flex;
  flex-direction: column;
}
