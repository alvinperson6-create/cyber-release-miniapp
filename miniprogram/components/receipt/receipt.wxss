/* ==================== 收据弹窗 ==================== */
.receipt-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(31, 58, 54, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  z-index: 100;
  padding: 48rpx;
}

.receipt-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.receipt-card {
  width: 100%;
  max-width: 660rpx;
  max-height: 88vh;
  overflow-y: auto;
  background: #faf6ec;
  border-radius: 32rpx;
  padding: 56rpx 40rpx 40rpx;
  transform: translateY(80rpx) scale(0.96);
  transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.3, 1);
  box-shadow: 0 48rpx 120rpx rgba(0, 0, 0, 0.3);
  position: relative;
}

.receipt-overlay.show .receipt-card {
  transform: translateY(0) scale(1);
}

/* 穿孔边缘 (上下) */
.receipt-card::before,
.receipt-card::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 16rpx;
  background-image: radial-gradient(circle, #faf6ec 8rpx, transparent 8rpx);
  background-size: 28rpx 16rpx;
  background-repeat: repeat-x;
  z-index: 1;
}

.receipt-card::before {
  top: -8rpx;
}

.receipt-card::after {
  bottom: -8rpx;
  transform: rotate(180deg);
}

.receipt-header {
  text-align: center;
  padding-bottom: 32rpx;
  border-bottom: 1px dashed #e0ddd5;
  margin-bottom: 32rpx;
}

.receipt-stamp {
  display: inline-block;
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 44rpx;
  color: #ed7d5b;
  letter-spacing: 0.4em;
  padding: 12rpx 32rpx 12rpx 40rpx;
  border: 4rpx solid #ed7d5b;
  border-radius: 8rpx;
  transform: rotate(-3deg);
  margin-bottom: 20rpx;
}

.receipt-subtitle {
  font-size: 20rpx;
  color: #999;
  letter-spacing: 0.16em;
}

.receipt-rows {
  margin-bottom: 8rpx;
}

.receipt-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  padding: 16rpx 0;
}

.receipt-row .row-key {
  color: #999;
}

.receipt-row .row-val {
  color: #2a2a2a;
}

.receipt-row .row-val.mono {
  font-family: "SF Mono", "Monaco", monospace;
  font-size: 24rpx;
}

.receipt-row .row-val.serif {
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 28rpx;
}

.receipt-feeling {
  margin: 28rpx 0;
  padding: 24rpx 28rpx;
  background: #f5ede0;
  border-radius: 16rpx;
  border-left: 6rpx solid #ed7d5b;
}

.receipt-sign {
  margin: 28rpx 0;
  padding: 28rpx;
  background: #d4e8e2;
  border-radius: 16rpx;
  text-align: center;
}

.receipt-feedback {
  margin: 28rpx 0 0;
  padding: 24rpx 28rpx;
  background: #d4e8e2;
  border-radius: 16rpx;
}

.block-label {
  font-size: 20rpx;
  letter-spacing: 0.14em;
  margin-bottom: 12rpx;
}

.receipt-feeling .block-label {
  color: #ed7d5b;
}

.receipt-sign .block-label {
  color: #1f3a36;
}

.receipt-feedback .block-label {
  color: #1f3a36;
}

.block-text {
  font-size: 26rpx;
  color: #2a2a2a;
  line-height: 1.6;
}

.receipt-feeling .block-text {
  font-style: italic;
}

.receipt-sign .block-text {
  font-family: "Kaiti SC", "STKaiti", serif;
  font-size: 32rpx;
  line-height: 1.5;
}

.receipt-feedback .block-text .strong {
  color: #1f3a36;
  font-weight: 600;
}

.receipt-feedback .block-text .mute {
  color: #999;
  font-size: 24rpx;
}

.receipt-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.btn-line {
  flex: 1;
  padding: 24rpx 0;
  background: transparent;
  border: 2rpx solid #e0ddd5;
  border-radius: 99rpx;
  font-size: 26rpx;
  color: #555;
  transition: all 0.2s;
}

.btn-line-active {
  border-color: #2c8a7a;
  color: #2c8a7a;
}

.btn-primary {
  flex: 1;
  padding: 24rpx 0;
  background: #1f3a36;
  color: #faf6ec;
  border-radius: 99rpx;
  font-size: 26rpx;
  letter-spacing: 0.06em;
  transition: all 0.2s;
}

.receipt-footer {
  text-align: center;
  font-size: 20rpx;
  color: #999;
  margin-top: 28rpx;
  letter-spacing: 0.02em;
  line-height: 1.6;
  display: flex;
  flex-direction: column;
}
