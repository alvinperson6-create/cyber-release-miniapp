/* release.wxss — 放生页样式 */

.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ========== 河流/水域视觉区 ========== */
.river-area {
  height: 400rpx;
  margin: 24rpx;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, var(--teal-light) 0%, var(--teal) 100%);
  box-shadow: 0 8rpx 24rpx rgba(44, 138, 122, 0.18);
}

/* 水波纹装饰 */
.river-area::before {
  content: '';
  position: absolute;
  top: 30%;
  left: -20%;
  width: 140%;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  pointer-events: none;
}

.river-area::after {
  content: '';
  position: absolute;
  top: 50%;
  left: -10%;
  width: 120%;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  pointer-events: none;
}

/* 热门气泡 */
.hot-bubbles {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 12rpx;
  pointer-events: none;
  z-index: 2;
}

.hot-bubble {
  background: rgba(255, 255, 255, 0.85);
  padding: 8rpx 20rpx;
  border-radius: 99rpx;
  font-size: 22rpx;
  color: var(--teal-deep);
  pointer-events: auto;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(31, 58, 54, 0.08);
}

/* 生物展示 */
.creature-display {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 80rpx;
  text-align: center;
  transition: transform 0.8s ease-out, opacity 0.8s ease-out;
  z-index: 1;
  line-height: 1;
}

.creature-display.released {
  transform: translate(-50%, calc(-50% + 200rpx)) scale(0.3);
  opacity: 0;
}

.creature-placeholder {
  font-size: 28rpx;
  color: var(--ink-mute);
  font-weight: 400;
}

/* 水域状态栏 */
.river-stat {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--ink-mute);
  z-index: 2;
}

.river-stat text {
  background: rgba(255, 255, 255, 0.7);
  padding: 4rpx 14rpx;
  border-radius: 99rpx;
}

/* ========== 面板区 ========== */
.panel {
  padding: 0 24rpx 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

/* 此刻感受 */
.feeling-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
}

.mic-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid var(--line);
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #fff;
  color: var(--ink-soft);
}

.mic-btn.recording {
  background: var(--coral);
  color: #fff;
  border-color: var(--coral);
  animation: mic-pulse 1.2s ease-in-out infinite;
}

@keyframes mic-pulse {
  0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(237, 125, 91, 0.4); }
  50% { transform: scale(1.08); box-shadow: 0 0 0 16rpx rgba(237, 125, 91, 0); }
}

.feeling-textarea {
  flex: 1;
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  min-height: 80rpx;
  background: #fff;
  box-sizing: border-box;
  line-height: 1.6;
}

.feeling-hint {
  font-size: 22rpx;
  color: var(--ink-mute);
  margin-top: 8rpx;
  padding-left: 88rpx;
}

/* 生物筹码 */
.chip-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

/* 水域网格 */
.water-scroll {
  max-height: 480rpx;
  border-radius: 12rpx;
}

.water-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.water-item {
  padding: 20rpx 12rpx;
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  text-align: center;
  font-size: 24rpx;
  background: #fff;
  transition: all 0.2s;
}

.water-item.active {
  border-color: var(--teal);
  background: var(--teal-light);
}

.water-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  line-height: 1;
}

.water-name {
  font-size: 24rpx;
  color: var(--ink);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.water-type {
  font-size: 20rpx;
  color: var(--ink-mute);
}

/* 回信时间 */
.fb-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.fb-opt {
  padding: 14rpx 28rpx;
  border: 2rpx solid var(--line);
  border-radius: 99rpx;
  font-size: 24rpx;
  color: var(--ink-soft);
  background: #fff;
}

.fb-opt.active {
  border-color: var(--teal);
  background: var(--teal-light);
  color: var(--teal-deep);
}

.custom-picker-trigger {
  margin-top: 16rpx;
  padding: 20rpx;
  border: 2rpx dashed var(--teal);
  border-radius: 12rpx;
  background: var(--teal-light);
  color: var(--teal-deep);
  font-size: 26rpx;
  text-align: center;
}

/* 放生按钮 */
.cta-btn {
  width: 100%;
  margin-top: 32rpx;
}

/* ========== 回执弹窗 ========== */
.receipt-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(31, 58, 54, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.receipt {
  background: var(--paper);
  width: 88%;
  border-radius: 24rpx;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-sizing: border-box;
  box-shadow: 0 16rpx 48rpx rgba(31, 58, 54, 0.25);
}

.receipt-head {
  text-align: center;
  margin-bottom: 32rpx;
}

.receipt-head .stamp {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--teal-deep);
  font-family: serif;
  letter-spacing: 8rpx;
  border: 4rpx double var(--teal-deep);
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  transform: rotate(-3deg);
}

.receipt-sub {
  font-size: 22rpx;
  color: var(--ink-mute);
  margin-top: 16rpx;
}

.receipt-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--line-soft);
}

.receipt-row .k {
  color: var(--ink-mute);
  font-size: 24rpx;
  flex-shrink: 0;
}

.receipt-row .v {
  color: var(--ink);
  font-size: 26rpx;
  font-weight: 600;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}

.receipt-feeling {
  margin: 24rpx 0;
  padding: 20rpx;
  background: var(--paper-warm);
  border-left: 6rpx solid var(--coral);
  border-radius: 8rpx;
}

.receipt-sign {
  margin: 24rpx 0;
  padding: 20rpx;
  background: var(--teal-light);
  border-radius: 8rpx;
}

.receipt-feedback {
  margin: 24rpx 0;
  padding: 20rpx;
  background: var(--teal-light);
  border-radius: 8rpx;
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  align-items: flex-start;
}

.feedback-emoji {
  font-size: 40rpx;
  flex-shrink: 0;
  line-height: 1;
}

.feedback-body {
  flex: 1;
}

.receipt-section-title {
  font-size: 24rpx;
  color: var(--teal-deep);
  font-weight: 600;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.receipt-feeling .receipt-section-title {
  color: var(--coral);
}

.receipt-section-text {
  font-size: 26rpx;
  color: var(--ink);
  line-height: 1.7;
}

.receipt-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-top: 32rpx;
}

.receipt-actions button {
  flex: 1;
  margin: 0;
}

.receipt-foot {
  margin-top: 24rpx;
  font-size: 20rpx;
  color: var(--ink-mute);
  text-align: center;
  line-height: 1.8;
}
