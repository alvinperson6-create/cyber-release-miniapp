/* ==================== 放生页样式 ==================== */
/* 严格还原 HTML 手机原型设计，纸质简洁风，无玻璃拟态 */

.page {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--paper);
  overflow: hidden;
}

/* ==================== 自定义导航栏 ==================== */
.phone-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 36rpx 24rpx;
  flex-shrink: 0;
}

.header-back {
  font-size: 36rpx;
  color: var(--ink-soft);
  line-height: 1;
}

.header-title {
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 36rpx;
  color: var(--ink);
}

.header-more {
  font-size: 32rpx;
  color: var(--ink-soft);
  letter-spacing: 2rpx;
}

/* ==================== 河流区域 ==================== */
.phone-river {
  position: relative;
  background: linear-gradient(180deg, #d4e8e2 0%, #b5d6cc 60%, #9bc8bd 100%);
  overflow: hidden;
  margin: 0 28rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
}

/* ==================== 世界地图 ==================== */
.world-map {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.map-image {
  position: absolute;
  top: 0;
  left: 0;
}

.water-markers {
  position: absolute;
  top: 0;
  left: 0;
}

/* ==================== 水域标记点 ==================== */
.water-marker {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 5;
}

.water-marker .dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #3e7a96;
  border: 3rpx solid #fff;
}

.water-marker.lake .dot {
  background: #2c8a7a;
}

.water-marker.river .dot {
  background: #2c8a7a;
}

.water-marker.trench .dot {
  background: #ed7d5b;
}

.water-marker.selected .dot {
  width: 28rpx;
  height: 28rpx;
  background: #ed7d5b;
  border: 5rpx solid #fff;
}

.water-marker .pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #ed7d5b;
  transform: translate(-50%, -50%);
  animation: mapPulse 1.8s ease-out infinite;
}

@keyframes mapPulse {
  0% {
    width: 28rpx;
    height: 28rpx;
    opacity: 0.7;
  }
  100% {
    width: 80rpx;
    height: 80rpx;
    opacity: 0;
  }
}

.water-label {
  position: absolute;
  top: -36rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: #1f3a36;
  font-weight: 600;
  white-space: nowrap;
  background: rgba(250, 246, 236, 0.9);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.water-marker.selected .water-label {
  color: #ed7d5b;
  background: rgba(252, 232, 223, 0.95);
}

/* ==================== 热门水域气泡 ==================== */
.hot-bubbles {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  display: flex;
  gap: 10rpx;
  z-index: 6;
  flex-wrap: wrap;
}

.hot-bubble {
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid #ed7d5b;
  border-radius: 99rpx;
  font-size: 22rpx;
  color: #ed7d5b;
  white-space: nowrap;
}

.hot-bubble.active {
  background: #ed7d5b;
  color: #fff;
}

/* ==================== 地图提示 ==================== */
.map-hint {
  position: absolute;
  bottom: 88rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  color: rgba(31, 58, 54, 0.65);
  letter-spacing: 0.1em;
  z-index: 4;
  background: rgba(255, 255, 255, 0.85);
  padding: 8rpx 28rpx;
  border-radius: 99rpx;
  white-space: nowrap;
  transition: opacity 0.4s;
}

.map-hint.hidden {
  opacity: 0;
}

/* ==================== 电子生物浮动层 ==================== */
.creature-layer {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  z-index: 3;
  transition: all 0.9s cubic-bezier(0.5, 0, 0.3, 1);
  pointer-events: none;
}

.creature-layer.released {
  bottom: -60%;
  opacity: 0;
  transform: translateX(-50%) scale(0.5);
}

.creature-img {
  width: 100%;
  animation: float 4s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) rotate(-2deg);
  }
  50% {
    transform: translateY(-8rpx) rotate(2deg);
  }
}

/* ==================== 水域统计栏 ==================== */
.river-stat {
  position: absolute;
  bottom: 16rpx;
  left: 20rpx;
  right: 20rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 22rpx;
  color: var(--ink-soft);
  display: flex;
  justify-content: space-between;
  z-index: 4;
}

.river-stat .num {
  color: var(--teal);
  font-weight: 600;
  font-family: "SF Mono", "Monaco", monospace;
}

.river-stat .muted {
  color: var(--ink-mute);
}

/* ==================== 控制面板 ==================== */
.phone-panel {
  padding: 28rpx 36rpx 36rpx;
  background: var(--paper);
  flex-shrink: 0;
}

.panel-label {
  font-size: 22rpx;
  color: var(--ink-mute);
  margin-bottom: 16rpx;
  letter-spacing: 0.08em;
}

.label-hint {
  color: var(--coral);
  font-size: 20rpx;
}

/* ==================== 感受输入 ==================== */
.feeling-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-end;
  margin-bottom: 12rpx;
}

.mic-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: var(--teal-light);
  border: 2rpx solid var(--teal);
  color: var(--teal-deep);
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.mic-btn.recording {
  background: var(--coral);
  border-color: var(--coral);
  color: #fff;
  animation: micPulse 1.2s ease-in-out infinite;
}

@keyframes micPulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(237, 125, 91, 0.4);
  }
  50% {
    box-shadow: 0 0 0 12rpx rgba(237, 125, 91, 0);
  }
}

.feeling-textarea {
  flex: 1;
  min-height: 76rpx;
  padding: 18rpx 24rpx;
  border: 2rpx solid var(--line);
  border-radius: 20rpx;
  background: #fdfaf2;
  font-size: 24rpx;
  color: var(--ink);
  line-height: 1.5;
}

.placeholder-style {
  color: var(--ink-mute);
  opacity: 0.7;
}

.feeling-hint {
  font-size: 20rpx;
  color: var(--ink-mute);
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.feeling-hint .dot {
  color: var(--coral);
  margin-right: 4rpx;
}

/* ==================== 生物选择 ==================== */
.chip-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.chip-btn {
  padding: 14rpx 24rpx;
  background: #fdfaf2;
  border: 2rpx solid var(--line);
  border-radius: 99rpx;
  font-size: 24rpx;
  color: var(--ink-soft);
}

.chip-btn.coral.active {
  background: var(--coral);
  color: #fff;
  border-color: var(--coral);
}

/* ==================== 回信时间 ==================== */
.fb-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.fb-opt {
  padding: 10rpx 20rpx;
  background: #fdfaf2;
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: var(--ink-soft);
}

.fb-opt.active {
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
}

.fb-date {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 12rpx 20rpx;
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--ink-soft);
  background: #fdfaf2;
}

/* ==================== 放生按钮 ==================== */
.cta-btn {
  width: 100%;
  margin-top: 16rpx;
  padding: 28rpx;
  background: linear-gradient(180deg, #ed7d5b 0%, #d96d4d 100%);
  color: #fff;
  border-radius: 99rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.1em;
  box-shadow: 0 8rpx 24rpx rgba(237, 125, 91, 0.32);
  position: relative;
  overflow: hidden;
  text-align: center;
}

.cta-btn.disabled {
  background: #d8d0bf;
  color: var(--paper);
  box-shadow: none;
}

.cta-btn-text {
  position: relative;
  z-index: 2;
}

.cta-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: shine 3s infinite;
}

@keyframes shine {
  0% {
    left: -100%;
  }
  60%, 100% {
    left: 100%;
  }
}
