<!-- 命运轨迹页 -->
<view class="page" style="padding-top: {{statusBarHeight}}px;">
  <!-- 自定义导航栏 -->
  <view class="phone-header">
    <text class="header-back" catchtap="onBackTap">‹</text>
    <text class="header-title">命运轨迹</text>
    <text class="header-more"></text>
  </view>

  <scroll-view class="destiny-scroll" scroll-y style="height: {{scrollHeight}}px;">
    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="destiny-loading">
      <view class="spinner"></view>
      <text>正在召唤命运轨迹…</text>
    </view>

    <!-- 错误 -->
    <view wx:elif="{{errorMsg}}" class="destiny-loading">
      <text>{{errorMsg}}</text>
    </view>

    <!-- 命运轨迹内容 -->
    <block wx:elif="{{destiny}}">
      <view class="destiny-header">
        <text class="destiny-title">命运轨迹</text>
        <text class="destiny-subtitle">DESTINY TRAJECTORY</text>
        <text class="destiny-record-id">{{destiny.recordId}}</text>
      </view>

      <!-- 段落列表 -->
      <view class="destiny-segments">
        <view wx:for="{{destiny.segments}}" wx:key="index"
              class="destiny-segment {{item.locked ? 'locked' : ''}}">
          <!-- banner -->
          <view class="seg-banner" style="background: {{item.bg}};">
            <text class="seg-index">第 {{item.index + 1}} 段</text>
            <text class="seg-emoji">{{item.emoji}}</text>
            <view wx:if="{{item.locked}}" class="seg-lock-overlay">
              <text class="lock-icon">🔒</text>
              <text class="lock-hint">{{item.unlockType === 'free' ? '免费' : '看广告解锁'}}</text>
            </view>
          </view>
          <!-- body -->
          <view class="seg-body">
            <text class="seg-title">{{item.title}}</text>
            <text wx:if="{{!item.locked}}" class="seg-text">{{item.text}}</text>
            <button wx:else
                    class="seg-unlock-btn"
                    data-index="{{item.index}}"
                    catchtap="onUnlockSegment">
              {{item.unlockType === 'free' ? '免费解锁' : '📺 看广告解锁'}}
            </button>
          </view>
        </view>
      </view>

      <!-- 底部操作 -->
      <view class="destiny-actions">
        <button wx:if="{{!destiny.allUnlocked}}"
                class="bundle-btn"
                catchtap="onUnlockBundle">
          📺 看广告 · 一次解锁全部
        </button>
      </view>

      <view class="destiny-footer">
        <text>放生瞬间 → 命运轨迹 → 最终回信</text>
      </view>
    </block>
  </scroll-view>
</view>

<!-- 广告模拟弹窗 -->
<view wx:if="{{adVisible}}" class="ad-overlay">
  <view class="ad-card">
    <view class="ad-banner">📺 广告</view>
    <view class="ad-body">
      <view class="ad-content">
        <text class="ad-placeholder">广告位</text>
        <text class="ad-tag">激励视频 · 观看完整后可解锁</text>
      </view>
      <view class="ad-countdown">
        <text wx:if="{{!adReady}}">剩余 {{adCountdown}} 秒</text>
        <text wx:else class="ad-ready-text">✓ 观看完成，可领取奖励</text>
      </view>
      <button class="ad-close-btn {{adReady ? 'ready' : ''}}"
              catchtap="onAdClose">
        {{adReady ? '领取奖励' : '请观看 ' + adCountdown + 's'}}
      </button>
    </view>
  </view>
</view>
