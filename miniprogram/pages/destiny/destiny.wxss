/* ==================== 命运轨迹页样式 ==================== */
.page {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--paper);
  overflow: hidden;
}

/* ==================== 自定义导航栏 ==================== */
.phone-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 36rpx 24rpx;
  flex-shrink: 0;
}

.header-back {
  font-size: 36rpx;
  color: var(--ink-soft);
  line-height: 1;
}

.header-title {
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 36rpx;
  color: var(--ink);
}

.header-more {
  font-size: 32rpx;
  color: var(--ink-soft);
  width: 36rpx;
}

/* ==================== 滚动区 ==================== */
.destiny-scroll {
  width: 100%;
  flex: 1;
}

/* ==================== 加载/错误 ==================== */
.destiny-loading {
  text-align: center;
  padding: 120rpx 40rpx;
  color: var(--ink-mute);
  font-size: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--line);
  border-top-color: var(--teal);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ==================== 头部 ==================== */
.destiny-header {
  text-align: center;
  padding: 24rpx 36rpx 28rpx;
  border-bottom: 1rpx dashed var(--line);
  margin: 0 28rpx 28rpx;
}

.destiny-title {
  display: block;
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 44rpx;
  color: var(--teal-deep);
  letter-spacing: 0.2em;
  margin-bottom: 8rpx;
}

.destiny-subtitle {
  display: block;
  font-size: 20rpx;
  color: var(--ink-mute);
  letter-spacing: 0.12em;
}

.destiny-record-id {
  display: block;
  font-family: "SF Mono", "Monaco", monospace;
  font-size: 20rpx;
  color: var(--ink-mute);
  margin-top: 8rpx;
}

/* ==================== 段落 ==================== */
.destiny-segments {
  padding: 0 28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.destiny-segment {
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid var(--line-soft);
  background: #fdfaf2;
  transition: opacity 0.3s;
}

.destiny-segment.locked {
  opacity: 0.85;
}

.seg-banner {
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.seg-index {
  position: absolute;
  top: 16rpx;
  left: 20rpx;
  font-size: 20rpx;
  color: rgba(255,255,255,0.9);
  font-family: "SF Mono", "Monaco", monospace;
  background: rgba(31,58,54,0.35);
  padding: 4rpx 16rpx;
  border-radius: 99rpx;
}

.seg-emoji {
  font-size: 64rpx;
}

.seg-lock-overlay {
  position: absolute;
  inset: 0;
  background: rgba(31, 58, 54, 0.55);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.lock-icon {
  font-size: 40rpx;
}

.lock-hint {
  font-size: 20rpx;
  color: #fff;
  letter-spacing: 0.1em;
  opacity: 0.9;
}

.seg-body {
  padding: 24rpx 28rpx 28rpx;
}

.seg-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 12rpx;
  letter-spacing: 0.04em;
}

.seg-text {
  display: block;
  font-size: 24rpx;
  color: var(--ink-soft);
  line-height: 1.7;
}

.seg-unlock-btn {
  width: 100%;
  margin-top: 12rpx;
  padding: 16rpx 0;
  background: var(--teal-deep);
  color: var(--paper);
  border-radius: 12rpx;
  font-size: 22rpx;
  letter-spacing: 0.06em;
  line-height: 1.5;
}

.seg-unlock-btn::after {
  border: none;
}

/* ==================== 底部操作 ==================== */
.destiny-actions {
  padding: 28rpx 28rpx 0;
}

.bundle-btn {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #ed7d5b, #d96d4d);
  color: #fff;
  border-radius: 99rpx;
  font-size: 26rpx;
  letter-spacing: 0.06em;
  line-height: 1.5;
}

.bundle-btn::after {
  border: none;
}

.destiny-footer {
  text-align: center;
  padding: 32rpx 28rpx 48rpx;
  font-size: 20rpx;
  color: var(--ink-mute);
  letter-spacing: 0.04em;
}
