/* pages/archive/archive.wxss */

.archive-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--paper);
}

/* 用户信息栏 */
.user-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--teal-light);
  color: var(--teal-deep);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
}

.user-id {
  font-size: 20rpx;
  color: var(--ink-mute);
  font-family: monospace;
}

.login-tag {
  margin-left: auto;
  font-size: 18rpx;
  color: var(--teal);
  background: var(--teal-light);
  padding: 4rpx 14rpx;
  border-radius: 99rpx;
}

/* 统计栏 */
.stats-row {
  display: flex;
  flex-direction: row;
  border-bottom: 1rpx solid var(--line-soft);
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
}

.stat-item .n {
  font-size: 48rpx;
  color: var(--teal);
  line-height: 1;
  font-family: serif;
}

.stat-item .n.coral {
  color: var(--coral);
}

.stat-item .l {
  font-size: 20rpx;
  color: var(--ink-mute);
  margin-top: 8rpx;
}

.stat-item + .stat-item {
  border-left: 1rpx solid var(--line-soft);
}

/* 记录列表 */
.record-list {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
  box-sizing: border-box;
}

.record-item {
  background: #fdfaf2;
  border: 1rpx solid var(--line-soft);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.record-head {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-num {
  font-size: 20rpx;
  color: var(--ink-mute);
  font-family: monospace;
}

.status-badge {
  font-size: 18rpx;
  padding: 4rpx 14rpx;
  border-radius: 99rpx;
}

.status-badge.done {
  background: var(--teal-light);
  color: var(--teal-deep);
}

.status-badge.pending {
  background: var(--coral-soft);
  color: var(--coral);
}

.record-meta {
  font-size: 22rpx;
  color: var(--ink-soft);
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.feeling-preview {
  font-size: 22rpx;
  color: var(--ink);
  font-style: italic;
  margin-top: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 回信块 */
.reply-block {
  margin-top: 20rpx;
  padding: 20rpx;
  background: var(--paper-warm);
  border-radius: 12rpx;
  border-left: 6rpx solid var(--teal);
}

.reply-label {
  font-size: 18rpx;
  color: var(--teal);
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.reply-img {
  width: 100%;
  height: 160rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.reply-text {
  font-size: 22rpx;
  color: var(--ink);
  line-height: 1.8;
}

/* 倒计时块 */
.countdown-block {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--coral-soft);
  border-radius: 12rpx;
  font-size: 20rpx;
  color: var(--coral);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.countdown-time {
  font-family: monospace;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--ink-mute);
  font-size: 26rpx;
  line-height: 2;
}
