/* ==================== 档案页样式 ==================== */
/* 严格还原 HTML 手机原型设计，纸质简洁风 */

.page {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--paper);
  overflow: hidden;
}

/* ==================== 自定义导航栏 ==================== */
.phone-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 36rpx 24rpx;
  flex-shrink: 0;
}

.header-back {
  font-size: 36rpx;
  color: var(--ink-soft);
  line-height: 1;
}

.header-title {
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 36rpx;
  color: var(--ink);
}

.header-more {
  font-size: 32rpx;
  color: var(--ink-soft);
  letter-spacing: 2rpx;
}

/* ==================== 档案滚动区 ==================== */
.archive-scroll {
  width: 100%;
  flex: 1;
}

/* ==================== 用户栏 ==================== */
.archive-user {
  padding: 28rpx 36rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.archive-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--teal-light);
  color: var(--teal-deep);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
}

.user-id {
  font-size: 20rpx;
  color: var(--ink-mute);
  font-family: "SF Mono", "Monaco", monospace;
  letter-spacing: 0.04em;
}

.login-tag {
  font-size: 18rpx;
  color: var(--teal);
  background: var(--teal-light);
  padding: 4rpx 14rpx;
  border-radius: 99rpx;
  letter-spacing: 0.06em;
  flex-shrink: 0;
}

/* ==================== 统计行 ==================== */
.archive-stats {
  display: flex;
  padding: 24rpx 36rpx;
  gap: 0;
  border-bottom: 1rpx solid var(--line-soft);
}

.archive-stat {
  flex: 1;
  text-align: center;
}

.archive-stat + .archive-stat {
  border-left: 1rpx solid var(--line-soft);
}

.stat-num {
  font-family: "Kaiti SC", "STKaiti", "Songti SC", serif;
  font-size: 48rpx;
  color: var(--teal);
  line-height: 1;
}

.stat-num.coral {
  color: var(--coral);
}

.stat-label {
  font-size: 20rpx;
  color: var(--ink-mute);
  margin-top: 8rpx;
  letter-spacing: 0.04em;
}

/* ==================== 记录列表 ==================== */
.archive-list {
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--ink-mute);
  font-size: 26rpx;
  line-height: 2;
  display: flex;
  flex-direction: column;
}

/* ==================== 记录卡片 ==================== */
.archive-item {
  background: #fdfaf2;
  border: 1rpx solid var(--line-soft);
  border-radius: 12rpx;
  padding: 24rpx;
}

.archive-item.has-reply {
  border-color: var(--line);
}

.archive-item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-num {
  font-size: 20rpx;
  color: var(--ink-mute);
  letter-spacing: 0.04em;
  font-family: "SF Mono", "Monaco", monospace;
}

.archive-status {
  font-size: 18rpx;
  padding: 4rpx 14rpx;
  border-radius: 99rpx;
  letter-spacing: 0.04em;
  white-space: nowrap;
}

.archive-status.done {
  background: var(--teal-light);
  color: var(--teal-deep);
}

.archive-status.pending {
  background: var(--coral-soft);
  color: var(--coral);
}

.item-meta {
  font-size: 22rpx;
  color: var(--ink-soft);
  margin-bottom: 8rpx;
}

.feeling-preview {
  font-size: 22rpx;
  color: var(--ink);
  font-style: italic;
  margin-top: 8rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ==================== 回信展开块 ==================== */
.archive-reply {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.35s ease, opacity 0.3s ease, margin-top 0.3s ease;
  margin-top: 0;
}

.archive-reply.expanded {
  max-height: 1200rpx;
  opacity: 1;
  margin-top: 20rpx;
}

.reply-label {
  font-size: 18rpx;
  color: var(--teal);
  letter-spacing: 0.12em;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.reply-image {
  width: 100%;
  height: 160rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-position: center;
  background-size: cover;
  background-repeat: no-repeat;
}

.reply-emoji {
  font-size: 56rpx;
}

.reply-text {
  font-size: 22rpx;
  color: var(--ink);
  line-height: 1.6;
  display: block;
}

/* ==================== 命运轨迹入口 ==================== */
.destiny-entry {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #e8d5f0, #c4a8d8);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.destiny-entry-label {
  font-size: 22rpx;
  color: var(--ink);
  font-weight: 500;
  letter-spacing: 0.04em;
}

.destiny-entry-progress {
  font-size: 20rpx;
  color: var(--ink-mute);
  background: rgba(255,255,255,0.6);
  padding: 4rpx 16rpx;
  border-radius: 99rpx;
}

/* ==================== 倒计时 ==================== */
.archive-countdown {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--coral-soft);
  border-radius: 12rpx;
  font-size: 20rpx;
  color: var(--coral);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.countdown-time {
  font-family: "SF Mono", "Monaco", monospace;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}
