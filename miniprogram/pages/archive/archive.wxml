<!-- 档案页 -->
<view class="page" style="padding-top: {{statusBarHeight}}px;">
  <!-- 自定义导航栏 -->
  <view class="phone-header">
    <text class="header-back" catchtap="onBackTap">‹</text>
    <text class="header-title">放生档案</text>
    <text class="header-more" catchtap="onMoreTap">···</text>
  </view>

  <!-- 档案内容区 -->
  <scroll-view class="archive-scroll" scroll-y style="height: {{scrollHeight}}px;">
    <!-- 用户栏 -->
    <view class="archive-user">
      <view class="archive-avatar">微</view>
      <view class="user-info">
        <text class="user-name">微信用户</text>
        <text class="user-id">ID ····3a7f</text>
      </view>
      <view class="login-tag">静默登录</view>
    </view>

    <!-- 统计行 -->
    <view class="archive-stats">
      <view class="archive-stat">
        <text class="stat-num">{{stats.total}}</text>
        <text class="stat-label">累计放生</text>
      </view>
      <view class="archive-stat">
        <text class="stat-num coral">{{stats.pending}}</text>
        <text class="stat-label">待回信</text>
      </view>
      <view class="archive-stat">
        <text class="stat-num">{{stats.replied}}</text>
        <text class="stat-label">已回信</text>
      </view>
    </view>

    <!-- 记录列表 -->
    <view class="archive-list">
      <block wx:if="{{records.length === 0}}">
        <view class="empty-state">
          <text>还没有放生记录</text>
          <text>去放生一只吧 🐟</text>
        </view>
      </block>
      <block wx:else>
        <view wx:for="{{records}}" wx:key="id"
              class="archive-item {{item.reply ? 'has-reply' : ''}}"
              data-idx="{{index}}"
              catchtap="onCardTap">
          <!-- 卡片头部 -->
          <view class="archive-item-head">
            <text class="item-num">{{item.id}}</text>
            <text class="archive-status {{item.reply ? 'done' : 'pending'}}">{{item.reply ? '已回信' : '待回信'}}</text>
          </view>
          <!-- 卡片元信息 -->
          <view class="item-meta">
            <text>{{item.creatureEmoji}} {{item.creatureName}} · {{item.waterName}} · {{item.timeStr}}</text>
          </view>
          <!-- 感受 -->
          <view class="feeling-preview">
            <text>"{{item.feeling}}"</text>
          </view>

          <!-- 已回信: 可展开的回信内容 -->
          <view wx:if="{{item.reply}}" class="archive-reply {{item.expanded ? 'expanded' : ''}}">
            <view class="reply-label">📬 AI 回信 · {{item.feedbackLabel}}</view>
            <view class="reply-image" style="background: {{item.reply.bg}};">
              <text class="reply-emoji">{{item.reply.emoji}}</text>
            </view>
            <text class="reply-text">{{item.reply.text}}</text>
          </view>

          <!-- 待回信: 倒计时 -->
          <view wx:else class="archive-countdown">
            <text>⏳ 回信倒计时</text>
            <text class="countdown-time">{{item.countdown}}</text>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
